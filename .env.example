# cortex-tutor configuration (copy to .env for local dev; NEVER commit .env)

# ── Auth (Keycloak — shared realm with the cortex Scala server) ──────────────
AUTH_ENABLED=true
KEYCLOAK_ISSUER_URL=https://keycloak.kakde.eu/realms/apps-prod
KEYCLOAK_CLIENT_ID=cortex-web
# Override the JWKS *fetch* URL only (the `iss` check still uses KEYCLOAK_ISSUER_URL). In production point
# this at the IN-CLUSTER Keycloak so token validation never hairpins through the public edge (Cloudflare),
# whose bot protection (Browser Integrity Check) 403s a non-browser client and breaks auth. See ADR-0003.
# KEYCLOAK_JWKS_URL=http://keycloak.identity.svc.cluster.local/realms/apps-prod/protocol/openid-connect/certs
# Local dev points at the in-compose Keycloak instead:
# KEYCLOAK_ISSUER_URL=http://localhost:8081/realms/cortex
# AUTH_ENABLED=false   # fast iteration: bypass auth, coach open to all

# ── Anthropic (homelab/allowlist tier — server-side key; NEVER commit) ───────
ANTHROPIC_API_KEY=
COACH_MODEL=claude-sonnet-4-6
GATE_MODEL=claude-haiku-4-5-20251001
# Tier-2 cost reconciliation only — used by a CronJob, never the serving pod:
ANTHROPIC_ADMIN_KEY=

# ── Who may use wk-1 / the owner Claude key (comma-separated GitHub logins). ─
# Everyone else uses BYOK (their own key, client-direct). Fails CLOSED.
COACH_HOMELAB_USERS=ani2fun

# ── wk-1 Ollama fallback (OpenAI-compatible). Unset → no local fallback. ─────
OLLAMA_URL=
OLLAMA_MODEL=
FORCE_LOCAL=false

# ── Postgres. Prod: the `tutor` schema in the SHARED cortex DB — one instance,
#    isolated by schema + uniquely-named liquibase tracking tables (no dedicated
#    tutor DB is deployed). Local dev: the dedicated compose Postgres on host
#    :5433 (not 5432) so this stack runs alongside a local cortex ./bin/dev. ────
DATABASE_URL=postgresql+asyncpg://cortex:cortex@localhost:5433/cortex

# ── MCP grounding server (Streamable HTTP; tutor's own service identity).
#    Local bind port 8001 (not 8081 — 8081 is cortex's Keycloak). ─────────────
MCP_URL=http://localhost:8001/mcp
MCP_SERVICE_TOKEN=
GROUNDING_PORT=8001

# ── CORS: the cortex SPA origins allowed to call this tutor cross-origin ─────
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:8080,https://cortex.kakde.eu

# ── Guards ───────────────────────────────────────────────────────────────────
COACH_MAX_CONTEXT_CHARS=200000
